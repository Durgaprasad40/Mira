# =============================================================================
# Mira — Environment Variable Template
# =============================================================================
# Copy this file to `.env.local` and fill in real values.
# NEVER commit a real `.env.local` or any file containing live secrets.
#
# Key-rotation / restriction notes:
# - The Google Maps key previously shipped in `.env.local` and `app.json`
#   (prefix AIzaSy…) MUST be rotated in Google Cloud Console and restricted
#   by Android package name + SHA-1 fingerprint and iOS bundle identifier
#   before any re-use. See P0-4 in the production-hardening log.
# - Sentry DSN is a public identifier and safe to ship in client builds,
#   but still keep the real value out of source control as a hygiene default.
# =============================================================================

# ---------------------------------------------------------------------------
# Convex
# ---------------------------------------------------------------------------
# Deployment identifier used by `npx convex dev` / codegen (dev only).
CONVEX_DEPLOYMENT=dev:your-convex-deployment-name

# App-side Convex backend URL (https://<deployment>.convex.cloud).
EXPO_PUBLIC_CONVEX_URL=https://your-convex-deployment.convex.cloud

# App-side Convex HTTP endpoint (https://<deployment>.convex.site).
EXPO_PUBLIC_CONVEX_SITE_URL=https://your-convex-deployment.convex.site

# ---------------------------------------------------------------------------
# Google Maps (platform-specific keys)
# ---------------------------------------------------------------------------
# Required for react-native-maps on Android and iOS. Use one key per platform
# so each can be locked down independently in Google Cloud Console.
#
#   - GOOGLE_MAPS_ANDROID_API_KEY
#       * Application restriction: Android apps
#       * Package name: com.mira.dating
#       * SHA-1 fingerprint: the debug + release signing certs you ship with
#       * API restriction: Maps SDK for Android ONLY
#
#   - GOOGLE_MAPS_IOS_API_KEY
#       * Application restriction: iOS apps
#       * Bundle ID: com.mira.dating
#       * API restriction: Maps SDK for iOS ONLY
#
# NEVER commit a real key to source control. Keys live only in .env.local
# (gitignored) and in your secret manager for CI/EAS builds.
GOOGLE_MAPS_ANDROID_API_KEY=your_android_key
GOOGLE_MAPS_IOS_API_KEY=your_ios_key

# Legacy single-key fallback. The app reads platform keys first, then falls
# back to this value. Safe to leave as the placeholder below.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ---------------------------------------------------------------------------
# Demo / development toggles (leave unset or `false` in production)
# ---------------------------------------------------------------------------
EXPO_PUBLIC_DEMO_MODE=false
EXPO_PUBLIC_DEMO_AUTH_MODE=false
EXPO_PUBLIC_SHOW_DEV_OTP=false

# ---------------------------------------------------------------------------
# Sentry (crash reporting)
# ---------------------------------------------------------------------------
EXPO_PUBLIC_SENTRY_DSN=https://<your-sentry-dsn>
EXPO_PUBLIC_SENTRY_DEBUG=false
