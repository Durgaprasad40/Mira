  UW PICO 5.09                                                                                     File: .env.local                                                                                       

# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=dev:proper-platypus-824 # team: durga-prasad, project: mira-475ce

EXPO_PUBLIC_CONVEX_URL=https://proper-platypus-824.convex.cloud

# Demo mode OFF - using Convex backend for Phase-1 users
# CRITICAL: Demo mode must be disabled for Phase-1 to persist photos to Convex backend
# When enabled, photos are stored only in local demoStore and lost on restart

EXPO_PUBLIC_CONVEX_SITE_URL=https://proper-platypus-824.convex.site

# Google Maps API Key (required for Android maps)
# Get your key from: https://console.cloud.google.com/apis/credentials
# Enable "Maps SDK for Android" and "Maps SDK for iOS"
GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_DEMO_MODE=false

# DEV-ONLY: Show OTP in alert for local development testing
EXPO_PUBLIC_SHOW_DEV_OTP=true
